{
  "name": "budgetwise-ai",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "pages:build": "remix vite:build",
    "deploy:pages": "wrangler pages deploy ./build/client",
    "preview": "wrangler pages dev ./build/client",
    "typecheck": "tsc --noEmit && tsc --noEmit -p remix/tsconfig.json",
    "lint": "eslint . --ext js,ts,tsx",
    "db:migrate": "wrangler d1 migrations apply budgetwise-db"
  },
  "dependencies": {
    "@remix-run/cloudflare": "2.10.3",
    "@remix-run/react": "2.10.3",
    "@supabase/supabase-js": "^2.39.0",
    "isbot": "^5.1.8",
    "jose": "^5.3.0",
    "lucide-react-native": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native-chart-kit": "^6.12.0",
    "react-native-svg": "^15.15.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@remix-run/dev": "2.10.3",
    "@remix-run/serve": "2.10.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vite": "^5.1.7",
    "wrangler": "^3.75.0"
  }
}
