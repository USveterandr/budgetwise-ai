# Development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
PLAID_CLIENT_ID=your_plaid_id
PLAID_SECRET=your_plaid_secret
DATABASE_URL=file:./dev.db

# Production (Cloudflare)
NEXT_PUBLIC_BASE_URL=https://budgetwise.yourdomain.com
# .env.local (Client-side)
NEXT_PUBLIC_BASE_URL=https://budgetwise.ai

# .env (Server-side)
PLAID_CLIENT_ID=your_id
PLAID_SECRET=your_secret
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
DATABASE_URL=postgresql://user:password@localhost:5432/budgetwise