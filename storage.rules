rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow reading public assets if any
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
